---
interface Props {
  title: string;
  style: string;
  image: string;
  date: string;
  description?: string;
}

const { title, style, image, date, description } = Astro.props;
---

<article class="artwork-card tattoo-card reveal" data-title={title} data-image={image}>
  <div class="card-img-wrap">
    <img
      src={image}
      alt={title}
      loading="lazy"
      onerror="this.src='/images/placeholder.svg'"
    />
    <div class="artwork-card-overlay">
      {description && (
        <p style="font-size:0.8rem;color:rgba(240,236,232,0.8);line-height:1.5;">{description}</p>
      )}
    </div>
  </div>

  <div class="artwork-card-info">
    <div class="flex justify-between items-center mb-1">
      <h3 style="font-family:var(--font-display);font-size:1.1rem;letter-spacing:0.04em;">{title}</h3>
    </div>
    <div class="flex gap-1 items-center">
      <span class="style-tag">{style}</span>
      <span class="text-muted" style="font-size:0.75rem;font-family:var(--font-mono);">
        {new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
      </span>
    </div>
  </div>
</article>
