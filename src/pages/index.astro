---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PaintingCard from '../components/PaintingCard.astro';
import { getCollection } from 'astro:content';

const allPaintings = await getCollection('paintings');
const allTattoos   = await getCollection('tattoos');

const featuredPaintings = allPaintings.filter((p) => p.data.featured).slice(0, 3);
const featuredTattoos   = allTattoos.filter((t) => t.data.featured).slice(0, 3);
---

<Layout title="Aashma — Tattoo Artist & Painter">
  <Nav />

  <!-- ─── HERO ─── -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container hero-inner">

      <!-- Text -->
      <div class="hero-text">
        <div class="section-eyebrow reveal">
          <span class="label">Al.Ink Studio · Kathmandu, Nepal</span>
        </div>

        <h1 class="display-xl reveal" style="transition-delay:0.05s;">
          Ink on<br />
          <span class="gradient-text">skin.</span><br />
          Paint on<br />
          <span style="color:var(--text-muted);">canvas.</span>
        </h1>

        <p class="reveal" style="transition-delay:0.1s;max-width:460px;font-size:1.1rem;color:var(--text-muted);margin:2rem 0 3rem;line-height:1.8;">
          Custom tattoos rooted in dark aesthetics. Original paintings exploring the threshold between beauty and void. One artist. Two mediums. Infinite dark.
        </p>

        <div class="flex gap-3 reveal" style="transition-delay:0.15s;flex-wrap:wrap;">
          <a href="/booking" class="btn btn-primary">Book a Tattoo</a>
          <a href="/shop" class="btn btn-outline">View Originals</a>
        </div>

        <div class="scroll-indicator reveal" style="transition-delay:0.3s;margin-top:5rem;display:flex;align-items:center;gap:0.75rem;">
          <div style="width:32px;height:1px;background:var(--text-dim);"></div>
          <span class="label" style="color:var(--text-dim);">Scroll</span>
        </div>
      </div>

      <!-- Media cluster -->
      <div class="hero-media">
        <div class="hero-media-grid">
          <video
            class="hero-vid-main"
            src="/videos/hero-1.mp4"
            autoplay muted loop playsinline preload="metadata"
          ></video>
          <div class="hero-media-side">
            <img src="/images/hero/hero-portrait.jpg" alt="Aashma — Al.Ink Studio" />
            <video
              src="/videos/hero-2.mp4"
              autoplay muted loop playsinline preload="metadata"
            ></video>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ─── FEATURED WORK ─── -->
  <section class="section">
    <div class="container">
      <div class="section-eyebrow reveal">
        <span class="label text-purple">Selected Work</span>
      </div>
      <h2 class="display-md reveal mb-8">Recent Pieces</h2>

      <!-- Masonry-style feature grid -->
      <div class="featured-grid reveal">
        {featuredPaintings.slice(0, 2).map((p) => (
          <PaintingCard
            slug={p.slug}
            title={p.data.title}
            year={p.data.year}
            medium={p.data.medium}
            price={p.data.price}
            sold={p.data.sold}
            image={p.data.image}
            series={p.data.series}
            size={p.data.size}
          />
        ))}
        {featuredTattoos.slice(0, 3).map((t) => (
          <article class="feat-tattoo-card reveal">
            <div class="feat-tattoo-accent"></div>
            <div class="feat-tattoo-body">
              <span class="style-tag">{t.data.style}</span>
              <h3 style="font-family:var(--font-display);font-size:1.2rem;margin-top:0.5rem;">{t.data.title}</h3>
              {t.data.description && (
                <p style="font-size:0.85rem;color:var(--text-muted);line-height:1.65;margin-top:0.75rem;display:-webkit-box;-webkit-line-clamp:5;-webkit-box-orient:vertical;overflow:hidden;">
                  {t.data.description}
                </p>
              )}
            </div>
          </article>
        ))}
      </div>

      <!-- Session videos -->
      <div class="session-grid" style="margin-top:3rem;">
        {['/videos/session-1.mp4', '/videos/session-2.mp4', '/videos/session-3.mp4', '/videos/session-4.mp4'].map((src) => (
          <div class="session-video-wrap reveal">
            <video
              src={src}
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
            />
          </div>
        ))}
      </div>

      <div class="flex gap-3 reveal" style="margin-top:3rem;flex-wrap:wrap;">
        <a href="/gallery/tattoos" class="btn btn-outline">All Tattoos</a>
        <a href="/gallery/paintings" class="btn btn-outline">All Paintings</a>
      </div>
    </div>
  </section>

  <!-- ─── SHOP PREVIEW ─── -->
  <section class="section" style="background:var(--bg-2);border-top:1px solid var(--border);border-bottom:1px solid var(--border);">
    <div class="container">
      <div class="flex justify-between items-center mb-8" style="flex-wrap:wrap;gap:1rem;">
        <div>
          <div class="section-eyebrow reveal">
            <span class="label text-cyan">Originals Available</span>
          </div>
          <h2 class="display-md reveal">Shop</h2>
        </div>
        <a href="/shop" class="btn btn-outline reveal">View All Works</a>
      </div>

      <div class="grid-gallery">
        {allPaintings.filter((p) => !p.data.sold).slice(0, 4).map((p) => (
          <PaintingCard
            slug={p.slug}
            title={p.data.title}
            year={p.data.year}
            medium={p.data.medium}
            price={p.data.price}
            sold={p.data.sold}
            image={p.data.image}
            series={p.data.series}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ─── BOOKING CTA ─── -->
  <section class="section">
    <div class="container">
      <div class="booking-cta glass reveal" style="padding:clamp(2rem,6vw,5rem);text-align:center;position:relative;overflow:hidden;border-top:2px solid var(--accent);">
        <div style="position:relative;">
          <div class="section-eyebrow" style="justify-content:center;margin-bottom:1rem;">
            <span class="label text-purple">Custom Tattoo</span>
          </div>
          <h2 class="display-lg" style="margin-bottom:1.5rem;">
            Ready to collaborate?
          </h2>
          <p class="text-muted" style="max-width:480px;margin:0 auto 2.5rem;font-size:1rem;line-height:1.8;">
            Each tattoo is a custom collaboration. Share your vision, your skin is the canvas. Limited availability — book early.
          </p>
          <div class="flex gap-3" style="justify-content:center;flex-wrap:wrap;">
            <a href="/booking" class="btn btn-primary">Request a Booking</a>
            <a href="/faq" class="btn btn-ghost">How it works →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── TESTIMONIALS ─── -->
  <section class="section" style="background:var(--bg-2);border-top:1px solid var(--border);">
    <div class="container">
      <div class="section-eyebrow reveal">
        <span class="label text-pink">Client Words</span>
      </div>
      <h2 class="display-md reveal mb-8">Testimonials</h2>

      <div class="testimonial-grid">
        {[
          {
            quote: "The most thoughtful tattoo experience I've had in Kathmandu. She understood exactly what I wanted — dark, geometric, alive. The sleeve is extraordinary.",
            name: "— Prasant Shrestha",
            tag: "Geometric Sleeve"
          },
          {
            quote: "Bought 'Neon Requiem' for my flat in Patan last year. It's the first thing I see every morning and it still stops me. Genuine dark beauty.",
            name: "— Pawan Shrestha",
            tag: "Painting Collector"
          },
          {
            quote: "From the first consultation at the studio to the final session, everything was clear and relaxed. The result was beyond what I imagined.",
            name: "— Sujata Maharjan",
            tag: "Fine Line Back Piece"
          },
          {
            quote: "I'd been putting off my first tattoo for years. She talked me through every detail and the healing was flawless. Already planning the next one.",
            name: "— Anish Tamang",
            tag: "Blackwork Forearm"
          },
        ].map((t) => (
          <blockquote class="glass testimonial reveal" style="padding:2rem;">
            <p style="font-size:1rem;line-height:1.8;margin-bottom:1.5rem;color:var(--text-muted);">"{t.quote}"</p>
            <footer>
              <span style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text);">{t.name}</span>
              <span class="style-tag" style="margin-left:0.75rem;">{t.tag}</span>
            </footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* ── Hero split layout ── */
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
    position: relative;
    z-index: 1;
    padding-top: 3rem;
    padding-bottom: 3rem;
  }

  .hero-media {
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .hero-media-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 0.75rem;
    width: 100%;
    height: min(calc(100svh - var(--nav-h) - 8rem), 700px);
  }

  .hero-vid-main {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-lg);
    display: block;
  }

  .hero-media-side {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: 0.75rem;
  }

  .hero-media-side img,
  .hero-media-side video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-lg);
    display: block;
  }

  /* ── Featured tattoo text cards ── */
  .feat-tattoo-card {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color var(--transition);
  }

  .feat-tattoo-card:hover { border-color: var(--border-hover); }

  .feat-tattoo-accent {
    height: 2px;
    background: var(--accent);
    flex-shrink: 0;
  }

  .feat-tattoo-body {
    padding: 1.25rem;
    flex: 1;
  }

  /* ── Featured grid ── */
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.25rem;
  }

  /* ── Session videos ── */
  .session-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .session-video-wrap video {
    width: 100%;
    aspect-ratio: 9/16;
    object-fit: cover;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    display: block;
  }

  .featured-grid > :nth-child(1) { grid-column: span 2; }
  .featured-grid > :nth-child(2) { grid-column: span 2; }
  .featured-grid > :nth-child(3) { grid-column: span 1; grid-row: span 1; }
  .featured-grid > :nth-child(4) { grid-column: span 2; }
  .featured-grid > :nth-child(5) { grid-column: span 3; }

  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 1100px) {
    .hero-inner { grid-template-columns: 1fr; gap: 0; padding-bottom: 0; }
    .hero-media { display: none; }
    .featured-grid { grid-template-columns: repeat(3, 1fr); }
    .featured-grid > * { grid-column: span 1; }
    .testimonial-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 720px) {
    .featured-grid { grid-template-columns: 1fr 1fr; }
    .session-grid { grid-template-columns: 1fr 1fr; }
    .testimonial-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
    .featured-grid { grid-template-columns: 1fr; }
    .session-grid { grid-template-columns: 1fr; }
  }
</style>
